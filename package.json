{
  "name": "quasar",
  "private": true,
  "version": "0.1.7",
  "description": "Local-first session and tool-call repository for AI agent histories.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skastr0/quasar.git"
  },
  "homepage": "https://github.com/skastr0/quasar#readme",
  "bugs": {
    "url": "https://github.com/skastr0/quasar/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/server typecheck && bun run --cwd packages/cli build",
    "typecheck": "bun run --cwd packages/server typecheck && bun run --cwd packages/cli typecheck",
    "test": "bun run --cwd packages/server test && bun run --cwd packages/cli test",
    "verify:static": "bun run typecheck && bun run test",
    "verify": "bun run verify:static",
    "server:deploy": "bun scripts/server-ops.mjs deploy",
    "server:up": "bun scripts/server-ops.mjs up",
    "server:down": "bun scripts/server-ops.mjs down",
    "server:restart": "bun scripts/server-ops.mjs restart",
    "server:ps": "bun scripts/server-ops.mjs ps",
    "server:logs": "bun scripts/server-ops.mjs logs",
    "server:ready": "bun scripts/server-ops.mjs ready",
    "server:health": "bun scripts/server-ops.mjs health",
    "server:status": "bun scripts/server-ops.mjs status",
    "server:lance": "bun scripts/server-ops.mjs lance",
    "server:maintain": "bun scripts/server-ops.mjs maintain",
    "server:materialize": "bun scripts/server-ops.mjs materialize",
    "server:materialize-staging": "bun scripts/server-ops.mjs materialize-staging",
    "server:backup": "bun scripts/server-ops.mjs backup",
    "proof:retrieval": "bun scripts/compare-local-search.mjs",
    "proof:materialize-staging": "bun scripts/materialize-staging-proof.mjs",
    "proof:sqlite-first": "bun packages/server/src/sqliteFirstProofCli.ts",
    "build:npm-packages": "bun run --cwd packages/cli build:npm-packages",
    "install:dev": "bun run --cwd packages/cli build && bun run --cwd packages/cli install:dev",
    "pack:dry-run": "bun scripts/pack-npm.mjs",
    "lint:npm-packages": "bun scripts/lint-npm-packages.mjs",
    "publish:npm": "bun scripts/publish-npm.mjs",
    "release:check": "bun run verify && bun run build && bun run build:npm-packages && bun run pack:dry-run && bun audit && bun run lint:npm-packages"
  },
  "devDependencies": {
    "publint": "^0.3.21",
    "@types/bun": "^1.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "effect": "^3.21.2",
    "js-tiktoken": "^1.0.21"
  },
  "overrides": {
    "ws": "8.21.0"
  }
}
