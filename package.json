{
  "name": "quasar",
  "private": true,
  "version": "0.1.3",
  "description": "Local-first session and tool-call repository for AI agent histories.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skastr0/quasar.git"
  },
  "homepage": "https://github.com/skastr0/quasar#readme",
  "bugs": {
    "url": "https://github.com/skastr0/quasar/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --cwd packages/core build && bun run --cwd packages/search build && bun run --cwd packages/local-server typecheck && bun run --cwd packages/cli build",
    "typecheck": "bun run --cwd packages/core typecheck && bun run --cwd packages/search typecheck && bun run --cwd packages/local-server typecheck && bun run --cwd packages/cli typecheck",
    "test": "bun run --cwd packages/core test && bun run --cwd packages/search test && bun run --cwd packages/local-server test && bun run --cwd packages/cli test",
    "verify:static": "bun run typecheck && bun run test",
    "verify": "bun run verify:static",
    "park:convex": "bun scripts/park-quasar-convex.mjs park",
    "status:convex": "bun scripts/park-quasar-convex.mjs status",
    "local-server:deploy": "bun scripts/local-server-ops.mjs deploy",
    "local-server:up": "bun scripts/local-server-ops.mjs up",
    "local-server:down": "bun scripts/local-server-ops.mjs down",
    "local-server:restart": "bun scripts/local-server-ops.mjs restart",
    "local-server:ps": "bun scripts/local-server-ops.mjs ps",
    "local-server:logs": "bun scripts/local-server-ops.mjs logs",
    "local-server:health": "bun scripts/local-server-ops.mjs health",
    "local-server:status": "bun scripts/local-server-ops.mjs status",
    "local-server:lance": "bun scripts/local-server-ops.mjs lance",
    "local-server:ingest": "bun scripts/local-server-ops.mjs ingest --provider all",
    "local-server:sync-tick": "bun scripts/local-server-ops.mjs sync-tick",
    "local-server:sync-install": "bun scripts/install-local-server-sync.mjs install",
    "local-server:sync-uninstall": "bun scripts/install-local-server-sync.mjs uninstall",
    "local-server:sync-status": "bun scripts/install-local-server-sync.mjs status",
    "local-server:maintain": "bun scripts/local-server-ops.mjs maintain --vector true --optimize true",
    "local-server:backup": "bun scripts/local-server-ops.mjs backup",
    "proof:retrieval": "bun scripts/compare-local-search.mjs",
    "build:npm-packages": "bun run --cwd packages/cli build:npm-packages",
    "install:dev": "bun run --cwd packages/cli build && bun run --cwd packages/cli install:dev",
    "pack:dry-run": "bun scripts/pack-npm.mjs",
    "publish:npm": "bun scripts/publish-npm.mjs",
    "release:check": "bun run verify && bun run build && bun run build:npm-packages && bun run pack:dry-run && bun audit && publish-scan ."
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/bun": "^1.3.1",
    "convex": "1.41.0",
    "convex-test": "^0.0.53",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.83",
    "ai": "^6.0.207",
    "effect": "^3.21.2",
    "js-tiktoken": "^1.0.21"
  }
}
