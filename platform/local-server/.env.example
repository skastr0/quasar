# Copy to platform/local-server/.env on the Mac mini. Do not commit real values.

# Reachability: prefer the Mac mini Tailscale IP for clients.
# If Docker Desktop refuses to bind the Tailscale interface directly, leave 0.0.0.0
# and restrict access with Tailscale ACLs / macOS firewall.
QUASAR_PUBLISH_HOST=0.0.0.0
QUASAR_LOCAL_PORT=6180

# Workers are disabled for first boot. For production, enable embedding + index repair after SQLite/LanceDB paths and keys are verified.
QUASAR_WORKERS_ENABLED=false
QUASAR_EMBEDDING_WORKER_ENABLED=false
QUASAR_INDEX_REPAIR_WORKER_ENABLED=false
QUASAR_FRESHNESS_WORKER_ENABLED=false
QUASAR_MAINTENANCE_WORKER_ENABLED=false
QUASAR_WORKER_INTERVAL_MS=5000
QUASAR_WORKER_BUSY_INTERVAL_MS=100
QUASAR_WORKER_LEASE_MS=600000
QUASAR_EMBEDDING_WORKER_LIMIT=1000
QUASAR_EMBEDDING_JOB_MAX_ATTEMPTS=12
QUASAR_EMBEDDING_API_BATCH_SIZE=100
QUASAR_EMBEDDING_API_CONCURRENCY=4
QUASAR_EMBEDDING_RETRY_BASE_MS=30000
QUASAR_EMBEDDING_RETRY_MAX_MS=600000
QUASAR_INDEX_WORKER_LIMIT=100
QUASAR_FRESHNESS_LIMIT=500
QUASAR_MAINTENANCE_VECTOR=true
QUASAR_MAINTENANCE_OPTIMIZE=true

# Embeddings. Synthetic/Nomic is the bulk text default when configured; Gemini remains available by profile.
QUASAR_EMBEDDING_PROVIDER=synthetic
QUASAR_EMBEDDING_MODEL=hf:nomic-ai/nomic-embed-text-v1.5
QUASAR_EMBEDDING_DIMENSIONS=768
QUASAR_EMBEDDING_TASK=search_document
QUASAR_EMBEDDING_DOCUMENT_PREFIX="search_document: "
QUASAR_EMBEDDING_QUERY_PREFIX="search_query: "
SYNTHETIC_API_KEY=

# Gemini embeddings. The AI SDK reads this provider key when QUASAR_EMBEDDING_PROVIDER=gemini.
GOOGLE_GENERATIVE_AI_API_KEY=

# Host history roots. Keep read-only in compose.
QUASAR_CODEX_ROOT=/Users/YOU/.codex
QUASAR_CLAUDE_ROOT=/Users/YOU/.claude
QUASAR_OPENCODE_ROOT=/Users/YOU/.local/share/opencode
QUASAR_GROK_ROOT=/Users/YOU/.grok
QUASAR_HERMES_ROOT=/Users/YOU/.hermes
QUASAR_KIMI_ROOT=/Users/YOU/.kimi-code
QUASAR_ANTIGRAVITY_ROOT=/Users/YOU/.gemini/antigravity-cli
