# Copy to platform/convex/.env for Docker Compose overrides.
# Keep admin keys only in the root .env.local consumed by the Convex CLI.

CONVEX_BACKEND_IMAGE=ghcr.io/get-convex/convex-backend@sha256:edd7959f3464ed661f6663f646db205d5d61bda606c969b074dfb3c69ed71463
CONVEX_DASHBOARD_IMAGE=ghcr.io/get-convex/convex-dashboard@sha256:bbc4d2c43d19fd6f2791dd6c5153a76e127f3eea489c1639e5acf66999c216bf

PORT=3217
SITE_PROXY_PORT=3218
DASHBOARD_PORT=5177

CONVEX_CLOUD_ORIGIN=https://quasar.tail6742f6.ts.net/quasar-convex
CONVEX_SITE_ORIGIN=https://quasar.tail6742f6.ts.net/quasar-api
NEXT_PUBLIC_DEPLOYMENT_URL=https://quasar.tail6742f6.ts.net/quasar-convex

APPLICATION_MAX_CONCURRENT_MUTATIONS=16
APPLICATION_MAX_CONCURRENT_NODE_ACTIONS=16
APPLICATION_MAX_CONCURRENT_QUERIES=16
