{
  "name": "@skastr0/quasar-control",
  "private": true,
  "version": "0.1.0",
  "description": "Private Convex and Next.js control app for Quasar.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "convex dev --start 'next dev --port 5177'",
    "build": "next build",
    "start": "next start --port 5177 --hostname 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --fileParallelism=false",
    "test:http-auth": "bun scripts/http-auth-smoke.mjs",
    "local:init": "bun scripts/initialize-local-convex.mjs",
    "local:backend": "bun scripts/start-local-convex.mjs",
    "local:push": "bun scripts/push-local-convex.mjs",
    "local:build": "bun scripts/build-tailscale.mjs",
    "local:serve": "next start --port 5177 --hostname 127.0.0.1",
    "local:publish": "bun run local:push && bun run local:build",
    "local:install-daemons": "bun scripts/install-launchd.mjs",
    "local:configure-tailscale": "bun scripts/configure-tailscale-serve.mjs",
    "local:backup": "bun scripts/backup-local-convex.mjs",
    "local:env": "bun scripts/configure-convex-env.mjs",
    "deploy": "bun scripts/deploy-local.mjs"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.75",
    "@convex-dev/migrations": "^0.3.4",
    "@convex-dev/rag": "^0.7.4",
    "@convex-dev/workpool": "^0.4.7",
    "@skastr0/quasar-core": "workspace:*",
    "ai": "^6.0.184",
    "convex": "^1.36.1",
    "effect": "^3.21.2",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@edge-runtime/vm": "^5.0.0",
    "@types/bun": "^1.3.1",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "convex-test": "^0.0.51",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.5"
  }
}
