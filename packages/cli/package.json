{
  "name": "@skastr0/quasar-cli",
  "version": "0.1.5",
  "description": "Command line importer and client for Quasar AI agent sessions.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "quasar": "bin/quasar.js"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/skastr0/quasar.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/skastr0/quasar#readme",
  "bugs": {
    "url": "https://github.com/skastr0/quasar/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run ./src/cli.ts",
    "build": "bun build --compile ./src/cli.ts --outfile ./dist/quasar",
    "install:dev": "bun scripts/install-dev.mjs",
    "install:local": "bun run install:dev",
    "build:npm-packages": "bun scripts/build-npm-packages.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "optionalDependencies": {
    "@skastr0/quasar-cli-darwin-arm64": "0.1.5",
    "@skastr0/quasar-cli-darwin-x64": "0.1.5",
    "@skastr0/quasar-cli-linux-arm64": "0.1.5",
    "@skastr0/quasar-cli-linux-x64": "0.1.5"
  },
  "devDependencies": {
    "@skastr0/quasar-local-server": "workspace:*",
    "@skastr0/quasar-search": "workspace:*",
    "@types/bun": "^1.3.1",
    "effect": "^3.21.2",
    "typescript": "^6.0.3"
  }
}
