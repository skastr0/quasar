{
  "name": "@quasar/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "quasar": "./src/cli.ts"
  },
  "scripts": {
    "dev": "bun run ./src/cli.ts",
    "build": "bun build ./src/cli.ts --target bun --outfile ./dist/quasar",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@quasar/core": "workspace:*",
    "effect": "^3.21.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
